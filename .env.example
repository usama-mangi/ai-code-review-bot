# GitHub App Credentials
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=          # Base64-encoded PEM private key
GITHUB_WEBHOOK_SECRET=           # Secret set when creating the GitHub App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI Provider (primary: openai | anthropic | google | openai-compatible)
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=          # optional, e.g. https://api.openrouter.ai/v1
OPENAI_MODEL=gpt-4o

# Anthropic (optional — used if AI_PROVIDER=anthropic or as fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google (optional — used if AI_PROVIDER=google or as fallback)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Fallback chain (optional — tried in order if primary fails)
AI_FALLBACK_1=
AI_FALLBACK_2=

# Database
DATABASE_URL=postgresql://codereview:codereview_secret@localhost:5432/codereview

# Redis
REDIS_URL=redis://localhost:6379

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
